        "@types/multer": "^1.4.13",
        "bcrypt": "^6.0.0",
        "bufferutil": "^4.1.0",
        "busboy": "^1.6.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.5.0",
        "express": "^5.1.0",
        "ioredis": "^5.6.1",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.0",
        "pg": "^8.16.0",
        "redis": "^4.6.13",
        "serverless-http": "^3.2.0",
